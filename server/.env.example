# OSS 对象存储配置
# 在阿里云控制台获取：https://ram.console.aliyun.com/manage/ak

# OSS 地域（如杭州：oss-cn-hangzhou）
OSS_REGION=oss-cn-hangzhou

# AccessKey ID（从阿里云 AccessKey 管理页面获取）
OSS_ACCESS_KEY_ID=你的 AccessKey ID

# AccessKey Secret（从阿里云 AccessKey 管理页面获取）
OSS_ACCESS_KEY_SECRET=你的 AccessKey Secret

# Bucket 名称（你创建的存储空间名，如 greyrabbit）
OSS_BUCKET=greyrabbit

# OSS Endpoint（本地开发用公网地址）
# 公网：oss-cn-hangzhou.aliyuncs.com
# 内网（仅线上服务器）：oss-cn-hangzhou-internal.aliyuncs.com
OSS_ENDPOINT=oss-cn-hangzhou.aliyuncs.com

# OSS 公网 Endpoint（前端访问用，和本地开发一样）
OSS_PUBLIC_ENDPOINT=oss-cn-hangzhou.aliyuncs.com

# OSS 数据存储根目录（生产环境：data，测试环境：datatest）
OSS_DATA_DIR=datatest

# 网站访问密码（用户首次访问时需要输入，3个月内无需再次输入）
ACCESS_PASSWORD=rabbit2024
